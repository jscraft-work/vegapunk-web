# Postgres DSN
# 컨테이너(jscraft 네트워크): postgresql://postgres:${DB_PASSWORD}@postgres:5432/vegapunk
# 호스트/로컬:              postgresql://postgres:${DB_PASSWORD}@localhost:5432/vegapunk
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/vegapunk

# Redis (이후 태스크용)
# 컨테이너: redis://redis:6379 / 호스트: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# dev | test | prod
APP_ENV=dev

# openclaw LLM (무상태, POST /ask). session_id는 전송하지 않음.
# ⚠ 컨테이너에선 localhost 금지. prod(맥미니): http://host.docker.internal:18000
OPENCLAW_BASE_URL=http://host.docker.internal:18000
OPENCLAW_API_KEY=
# level 값: 'normal'(빠름, 다시쓰기/제목) 또는 'high'(답변/요약, nanobot)만 허용. low 없음!
OPENCLAW_MODEL_LOW=normal
OPENCLAW_MODEL_DEFAULT=high

# compose db 비밀번호(docker-compose.yml에서 사용)
DB_PASSWORD=CHANGE_ME

# 인증/세션
SECRET_KEY=CHANGE_ME_RANDOM
OAUTH_REDIRECT_BASE=http://localhost:8000
# GitHub Actions는 GITHUB_ 접두 시크릿 금지 → GH_ 사용
GH_CLIENT_ID=
GH_CLIENT_SECRET=
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
